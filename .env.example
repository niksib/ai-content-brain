# Database
DB_PASSWORD=changeme
DATABASE_URL=postgresql://app:changeme@localhost:5432/daily_content_brain

# Auth (Better Auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Set to "true" when frontend and backend are on different registrable domains in production.
# Requires HTTPS on the backend — enables SameSite=None; Secure cookies.
AUTH_CROSS_SITE_COOKIES=false

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# Stripe price IDs for subscription plans (create in Stripe dashboard)
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=

# Threads API
THREADS_APP_ID=your_threads_app_id
THREADS_APP_SECRET=your_threads_app_secret
THREADS_REDIRECT_URI=http://localhost:3001/api/threads/callback

# Google Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
# Service account JSON key as a single-line string (no newlines)
GCS_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}

# URLs
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
