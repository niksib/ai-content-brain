# === Заполнить на VM, не коммитить ===

# Docker images (проставляется автоматически при деплое)
REGISTRY=ghcr.io/your-github-username/ai-content-brain
IMAGE_TAG=latest

# Database
DB_PASSWORD=

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://yourdomain.com

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=https://yourdomain.com/api/threads/callback

# URLs
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com
