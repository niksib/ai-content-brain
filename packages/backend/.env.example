# Используется при локальном запуске через `pnpm dev` (без Docker)
# Скопировать: cp .env.example .env

# Database (локальный postgres из docker-compose)
DATABASE_URL=postgresql://app:changeme@localhost:5432/daily_content_brain

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_VOICE=
STRIPE_PRICE_CHORUS=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=http://localhost:3001/api/threads/callback

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
