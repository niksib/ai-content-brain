generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== BETTER AUTH TABLES ====================

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions          Session[]
  accounts          Account[]
  memoryBlocks      MemoryBlock[]
  onboardingSession OnboardingSession?
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==================== MEMORY BLOCKS ====================

model MemoryBlock {
  id          String   @id @default(cuid())
  userId      String
  key         String
  title       String
  description String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// ==================== ONBOARDING SESSION ====================

model OnboardingSession {
  id                 String    @id @default(cuid())
  userId             String    @unique
  currentStep        String
  threadsAnalysis    Json?
  generatedQuestions Json?
  answers            Json?
  summary            String?
  clarification      String?
  analysisStartedAt  DateTime?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  lastActiveAt       DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== CHAT SESSION ====================

model ChatSession {
  id              String        @id @default(cuid())
  userId          String
  type            SessionType
  status          SessionStatus @default(active)
  sessionDate     DateTime      @db.Date

  sdkSessionId    String?       @unique

  messages        ChatMessage[]
  contentPlan     ContentPlan?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([userId, sessionDate])
}

enum SessionType {
  onboarding
  daily
}

enum SessionStatus {
  active
  completed
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id])

  role          MessageRole
  content       String
  audioUrl      String?
  costUsd       Float?

  contentIdeaId String?
  contentIdea   ContentIdea? @relation(fields: [contentIdeaId], references: [id])

  createdAt     DateTime    @default(now())
}

enum MessageRole {
  user
  assistant
}

// ==================== CONTENT PLAN ====================

model ContentPlan {
  id             String       @id @default(cuid())
  userId         String
  chatSessionId  String       @unique
  chatSession    ChatSession  @relation(fields: [chatSessionId], references: [id])

  ideas          ContentIdea[]

  createdAt      DateTime     @default(now())
}

// ==================== CONTENT IDEAS ====================

model ContentIdea {
  id            String        @id @default(cuid())
  contentPlanId String
  contentPlan   ContentPlan   @relation(fields: [contentPlanId], references: [id])
  userId        String

  platform      Platform
  format        ContentFormat
  angle         String
  description   String
  // Direct quote from the user — passed to platform agent to preserve voice.
  // Empty string when the user did not say anything quote-worthy.
  sourceQuote   String        @default("")
  // Negative-signal hints from strategist to platform agent (e.g. "don't end
  // with a takeaway"). Empty array when no specific traps to flag.
  doNot         String[]      @default([])

  status        IdeaStatus    @default(proposed)

  publishStatus String?   // "posted" | "scheduled"
  scheduledAt   DateTime? // set when post is scheduled for publishing
  publishedAt   DateTime? // set when post is actually published
  threadsPostId String?   // Threads media ID after publishing

  producedContent   ProducedContent?
  chatMessages      ChatMessage[]
  insightsSnapshots ThreadsInsightsSnapshot[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum Platform {
  threads
  linkedin
  tiktok
  instagram
}

enum ContentFormat {
  text_post
  text_with_image
  image_series
  video_script
  carousel
  stories
}

enum IdeaStatus {
  proposed
  approved
  rejected
  producing
  completed
}

// ==================== PRODUCED CONTENT ====================

model ProducedContent {
  id            String      @id @default(cuid())
  contentIdeaId String      @unique
  contentIdea   ContentIdea @relation(fields: [contentIdeaId], references: [id])
  userId        String

  platform      Platform
  format        ContentFormat

  body            Json
  imageSuggestion Json?

  createdAt     DateTime    @default(now())
}

// ==================== CREDITS ====================

model CreditBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(free)
  status               SubscriptionStatus @default(active)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum SubscriptionPlan {
  free
  creator
  pro
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  incomplete
}

// Log of processed Stripe webhook events. Existence of a row with a given
// `eventId` means we've already applied that event's side effects — skip reprocess.
model StripeWebhookEvent {
  eventId    String   @id
  type       String
  receivedAt DateTime @default(now())
}

// Single-use OAuth state nonces for Threads login / connect flows.
// A row is created when we issue a state, deleted on the callback. Expired
// rows are cleaned up opportunistically.
model OAuthState {
  nonce     String   @id
  purpose   String   // "login" | "connect"
  userId    String?  // bound user for "connect" flow; null for "login"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model CreditTransaction {
  id        String                @id @default(cuid())
  userId    String
  amount    Int
  type      CreditTransactionType
  reference String?

  model               String?
  inputUncachedTokens Int?
  inputCachedTokens   Int?
  cacheWriteTokens    Int?
  outputTokens        Int?
  costCents           Int?

  createdAt DateTime              @default(now())
}

enum CreditTransactionType {
  trial_grant
  subscription_grant
  topup_purchase
  voice_processing
  content_plan
  content_production
  agent_call
}

// ==================== MEDIA FILES ====================

model MediaFile {
  id        String   @id @default(cuid())
  userId    String
  url       String
  gcsPath   String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  duration  Int?     // seconds, for video

  createdAt DateTime @default(now())

  @@index([userId])
}

// ==================== THREADS INTEGRATION ====================

model ThreadsAccount {
  id                String   @id @default(cuid())
  userId            String   @unique
  threadsUserId     String
  username          String   @default("")
  name              String?
  biography         String?
  profilePictureUrl String?
  accessToken       String
  tokenExpiresAt    DateTime
  scopes            String
  isPrivateProfile  Boolean  @default(false)
  postsCount        Int      @default(0)

  styleAnalyzed     Boolean  @default(false)
  styleAnalyzedAt   DateTime?

  // Random per-user secret used to drive better-auth signIn on Threads OAuth
  // callback. Never exposed to clients. Nullable for backward compat with
  // rows created before the migration — those users go through the one-time
  // rekey path on their next OAuth callback.
  loginSecret       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  scheduledPosts    ScheduledPost[]
}

model ScheduledPost {
  id               String                 @id @default(cuid())
  userId           String
  threadsAccountId String
  threadsAccount   ThreadsAccount         @relation(fields: [threadsAccountId], references: [id])

  contentIdeaId    String?
  text             String
  posts            Json?                  // populated for multi-post threads instead of text
  mediaType        ScheduledPostMediaType @default(TEXT)
  mediaUrl         String?

  scheduledAt      DateTime
  publishingAt     DateTime?              // set when worker picks up the post; null otherwise
  attempts         Int                    @default(0)
  status           ScheduledPostStatus    @default(pending)
  threadsPostId    String?
  errorMessage     String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, scheduledAt])
}

// ==================== THREADS INSIGHTS ====================

model ThreadsInsightsSnapshot {
  id            String      @id @default(cuid())
  contentIdeaId String
  contentIdea   ContentIdea @relation(fields: [contentIdeaId], references: [id])
  userId        String

  views         Int?
  likes         Int?
  replies       Int?
  reposts       Int?
  quotes        Int?
  shares        Int?

  fetchedAt     DateTime    @default(now())

  @@index([contentIdeaId, fetchedAt(sort: Desc)])
}

enum ScheduledPostMediaType {
  TEXT
  IMAGE
  VIDEO
}

// ==================== META PLATFORM CALLBACKS ====================
// Tracks user-data-deletion requests initiated by Meta when a Threads user
// removes the app *and* asks for data deletion. Status URL exposes progress
// to the user via the confirmationCode they get from Meta.
model DataDeletionRequest {
  id               String    @id @default(cuid())
  confirmationCode String    @unique
  threadsUserId    String
  status           String    @default("pending") // pending | in_progress | completed | failed
  errorMessage     String?
  requestedAt      DateTime  @default(now())
  completedAt      DateTime?

  @@index([threadsUserId])
}

enum ScheduledPostStatus {
  pending
  publishing
  published
  failed
}
